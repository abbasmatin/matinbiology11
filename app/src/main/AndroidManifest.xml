<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Biology11">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.ChapterListActivity" android:exported="false" />
        <activity android:name=".ui.TextContentActivity" android:exported="false" />
        <activity android:name=".ui.ImageDescriptionsActivity" android:exported="false" />
        <activity android:name=".ui.KeyPointsActivity" android:exported="false" />
        <activity android:name=".ui.EssayQuestionsActivity" android:exported="false" />
        <activity android:name=".ui.McqActivity" android:exported="false" />
        <activity android:name=".ui.AboutActivity" android:exported="false" />
        <activity android:name=".ui.PdfViewActivity" android:exported="false" />

    </application>
</manifest>
